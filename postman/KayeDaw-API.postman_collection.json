                  "",
                  "const body = pm.response.json();",
                  "pm.test('Un jeton est retourné', () => pm.expect(body.token).to.be.a('string').and.not.empty);",
                  "",
                  "// On rafraîchit le jeton courant",
                  "pm.environment.set('token', body.token);",
                  "pm.collectionVariables.set('token', body.token);"
                ]
