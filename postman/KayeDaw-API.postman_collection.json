      "item": [
        {
          "name": "Créer une séance",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Statut 201 Created', () => pm.response.to.have.status(201));",
                  "",
                  "pm.test('En-tête Location présent', () => {",
                  "    pm.expect(pm.response.headers.get('Location')).to.include('/api/seances/');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Allure calculée : 50 min / 10 km = 5.0', () => {",
                  "    pm.expect(body.allureMinParKm).to.eql(5.0);",
                  "});",
                  "",
                  "pm.test('Vitesse calculée : 12 km/h', () => {",
                  "    pm.expect(body.vitesseKmH).to.eql(12.0);",
                  "});",
                  "",
                  "pm.environment.set('seanceId', body.id);",
                  "pm.collectionVariables.set('seanceId', body.id);"
                ]
              }
            }
