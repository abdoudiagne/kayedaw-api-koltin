      "name": "5. Appel sortant (WebClient)",
      "item": [
        {
          "name": "Conditions météo d'une ville",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 ou 204 selon la disponibilité du service externe', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    const b = pm.response.json();",
                  "    pm.test('Ville retournée', () => pm.expect(b.ville).to.be.a('string'));",
                  "    pm.test('Alertes présentes sous forme de liste', () => pm.expect(b.alertes).to.be.an('array'));",
                  "    console.log('Température max :', b.temperatureMaxC, '°C | alertes :', b.alertes);",
                  "} else {",
                  "    console.log('Service météo indisponible : repli en 204, comportement attendu.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/meteo/conditions?ville=Lille&date=2026-07-19",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "meteo",
                "conditions"
              ],
              "query": [
                {
                  "key": "ville",
                  "value": "Lille"
                },
                {
                  "key": "date",
                  "value": "2026-07-19"
                }
              ]
            },
            "description": "Appel sortant réel : géocodage puis météo et qualité de l'air en parallèle (WebClient + coroutines). Retourne 204 si le service externe est injoignable — la panne externe ne provoque jamais de 500."
